# scripted/written by Robert Bopko (github.com/zeroznet) with Boba Bott (Claude Opus 4.7)

# Dev container for wsl-vpnfix Phase A.
# Mirrors the Phase B production runtime as closely as possible:
# same Alpine base pinned by digest, same nftables / iproute2 packages.
# Adds Go + git for the build/test workflow that does not ship.
#
# Track current Alpine (security tool — stale base = stale build-tool CVEs).
# Update digest by re-pulling alpine:latest and copying the new RepoDigest;
# bump the apk-pinned versions in lockstep.
FROM alpine@sha256:4d889c14e7d5a73929ab00be2ef8ff22437e7cbc545931e52554a7b00e123d8b

RUN apk add --no-cache \
        go=1.25.9-r0 \
        nftables \
        iproute2 \
        git \
        ca-certificates

ENV CGO_ENABLED=0 \
    GOPATH=/root/go \
    GOCACHE=/root/.cache/go-build \
    PATH=/root/go/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

WORKDIR /work
